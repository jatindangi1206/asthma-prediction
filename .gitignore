__pycache__/
.venv/
venv/
*.pyc

raw_data.zip

# Raw wearable data — bulky, contains all participants.
# Ignore everything except participant 0010 (folder name includes literal quotes).
/raw_data/*
!/raw_data/"0010"/
!/raw_data/processed_users.txt

# Pipeline outputs: ignore everything under data/ ...
/data/*

# ... but keep participant 0010's data and plots only.
# (each level must be re-included before the file inside it)
!/data/processed/
/data/processed/*
!/data/processed/0010_processed.csv

!/data/smoothed/
/data/smoothed/*
!/data/smoothed/0010_smoothed.csv

!/data/annotated/
/data/annotated/*
!/data/annotated/0010_annotated.csv

!/data/plots/
/data/plots/*
!/data/plots/0010_*.png

# EDA results: keep only participant 0010 and global summary figures,
# plus the two JSON/CSV summary files. Ignore all other per-patient PNGs.
!/data/results/
/data/results/*
!/data/results/eda_smoothed/
/data/results/eda_smoothed/*
!/data/results/eda_smoothed/0010_eda.png
!/data/results/eda_smoothed/global_eda.png
!/data/results/eda_smoothed/all_patients_summary.csv
!/data/results/eda_smoothed/hrv_characteristics_post_smoothing.json
